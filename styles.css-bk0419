}

/* スライドショー */
#slideshow {
  margin-bottom: 20px;
  width: 80%;
  max-width: 600px;
  overflow: hidden;
  margin: 0 auto;
}

/* monument-container中央寄せ */
.monument-container {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: flex-start;
  margin: 0 auto 20px auto;
  width: 100%;
  gap: 40px;
  max-width: 800px;
}

.monument {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.monument-image-wrapper img {
  width: 220px;
  height: auto;
  max-width: 100%;
  border-radius: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.10);
  background: #e6f2fa;
}

#slideshow img {
  width: 100%;
  display: none;
  margin: 0 auto;
}

#slideshow img.active {
  display: block;
  margin: 0 auto;
}


/* テーブル */
table {
  width: 100%;
  margin: 0px auto;
  margin-bottom: 0px;
  /* タイトルの下の余白を10pxに設定 */
  border-collapse: collapse;
  margin-top: -20px;
}

th,
td {
  border: 1px solid #0000ff;
  padding: 8px;
  text-align: center;
}

th {
  background-color: #8000c0;
  color: #fff;
  font-size: 1.13em;
  font-weight: bold;
  letter-spacing: 1px;
  border-bottom: 3px solid #fff;
}

td:first-child {
  background-color: #0033cc;
  color: #ffff00;
  font-weight: bold;
  font-size: 1.1em;
}

td {
  background-color: #f9cccc;
}

#amami-table {
  border: 3px solid rgb(248, 199, 207);
  /* 戻る際に一時的に目立たせる */
}


h2 {
  margin-bottom: 0px;
  /* タイトルの下の余白を10pxに設定
        color: #0000ff;  H3タグを紫に設定 */
}

h5 {
  margin-bottom: 0px;
  /* タイトルの下の余白を10pxに設定
        color: #0000ff;  H3タグを紫に設定  */
  background-color: light blue;
}

h3 {
  color: rgb(128, 0, 128);
  /* H3タグを紫に設定 */
}


/* ご意見・ご要望欄 */
.feedback,
.purple-border-bgm {
  width: 100%;
  /* 上段の幅に合わせる */
  max-width: 400px;
  /* 最大幅を制限して調整 */
  margin: 20px auto;
  /* 中央配置を維持 */
}

.feedback,
.purple-border-bgm {
  width: 400px;
  margin: 20px auto;
  box-sizing: border-box;
  /* 余白や枠線を含めてサイズ計算 */
}


.feedback {
  text-align: center;
  color: purple;
  margin: 20px auto;
  width: 400px;
  border: 2px solid rgb(128, 0, 128);
  padding: 10px;
  border-radius: 10px;
}

/* BGMとカウント数 */
.centered {
