/* 島タイトル行の重なり防止・デザイン */
.island-title-row td {
  background: #0033cc !important;
  color: #fff !important;
  font-weight: bold;
  text-align: center;
  padding: 12px 0 !important;
  font-size: 1.18em;
  border: 3px solid #fff;
  width: 100%;
  box-sizing: border-box;
  letter-spacing: 2px;
}

/* テーブルとタイトルの間隔調整 */
#amami-table {
  margin-top: 0px !important;
  border: 4px solid #0033cc;
  font-weight: bold;
  font-size: 1.1em;
  box-shadow: 0 2px 12px rgba(0,0,0,0.08);
}

/* テーブルヘッダーとデータセルの余白調整 */
th, td {
  border: 2px solid #0033cc !important;
  padding: 12px 6px !important;
  text-align: center;
  font-weight: bold;
  font-size: 1.08em;
}
#counterContainer {
  color: blue;
  margin-top: 20px;
  /* ← この行で下にずらす */
}

/* Removed JavaScript code from CSS file */
body {
  background-color: #b6e1f3;
  /* 薄いグリーン */
  text-align: center;
  font-family: Arial, sans-serif;
}

h1.title {
  text-align: center;
  color: rgb(5, 5, 251);
  font-weight: bold;
}

/* 言語切り替え部分のスタイル */
.language-switcher {
  position: fixed;
  /* 必要に応じてabsoluteに変更 */
  z-index: 1000;
  /* Googleのバナーよりも前面に表示 */
  background-color: white;
  /* 必要なら背景色を設定して明瞭化 */
  padding: 5px;
  /* 隠れにくくするための余白 */
}

/* Google翻訳バーの容器　html内 */
#google_translate_element {
  display: inline-block;
}

/* 一段目：3分割テーブル形式 */
.top-bar {
  display: table;
  width: 100%;
  background-color: #33b5ecdb;
  border-collapse: collapse;
  table-layout: fixed;
  position: fixed;
  /* 画面の最上部に固定 */
  top: 0;
  /* 上から0pxの位置 */
  z-index: 1000;
  /* 他の要素より前面に配置 */

}

/* モーダルのスタイル */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background-color: #fff;
  padding: 20px;
  border-radius: 8px;
  width: 80%;
  max-width: 800px;
  position: relative;
}

.close-btn {
  position: absolute;
  top: 10px;
  right: 10px;
  font-size: 20px;
  cursor: pointer;
  background: rgb(220, 20, 60);
  color: rgb(255, 255, 255);
  border: none;
  border-radius: 5px;
  padding: 5px 10px;
}

.popup-overlay {
  display: none;
  /* 初期状態では非表示　PDF読み込み */
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  /* 背景を暗くするPdf読み込み */
  z-index: 1000;
  /* 最前面に表示 */
}

.popup-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgb(255, 255, 255);
  padding: 20px;
  border-radius: 5px;
  width: 80%;
  height: 80%;
  box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.3);
}

.close-btn {
  /* pdfpopup */
  position: absolute;
  top: 10px;
  right: 10px;
  cursor: pointer;
  background: #f44336;
  color: rgb(255, 255, 255);
  border: none;
  padding: 5px 10px;
  border-radius: 3px;
}

.close-btn2 {
  position: absolute;
  top: 10px;
  right: 10px;
  cursor: pointer;
  z-index: 1020;
  /* ボタンが上に表示されるように */
}


.popup-overlay2 {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  /* 背景を暗くする */
  z-index: 1000;
  /* 最前面に表示 */
}

.popup-content2 {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgb(255, 255, 255);
  padding: 20px;
  border-radius: 5px;
  width: 80%;
  height: 90%;
  z-index: 1010;
  /* オーバーレイ内で最前面 */
}

/* 最上部に配置するリンクボックス */
.header-links {
  position: fixed;
  top: 0;
  width: 100%;
  display: flex;
  justify-content: space-between;
  padding: 0px;
  z-index: 9999;
  background-color: #fff;
  margin: 0;
  /* 最上段ボックスの外部マージンをゼロに */
}

.link-box {
  background-color: #4CAF50;
  padding: 10px 20px;
  border-radius: 5px;
  text-align: center;
  color: rgb(255, 255, 255);
  font-size: 14px;
}

.link-box a {
  color: rgb(251, 249, 249);
  text-decoration: none;
}

.link-box.left {
  margin-left: 0px;
  padding-left: 0;
}

.link-box.right {
  margin-right: 10px;
}

/* ポップアップのスタイル */
.popup {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: rgb(255, 255, 255);
  border: 1px solid #ccc;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  padding: 20px;
  width: 300px;
  display: none;
}

.popup a {
  display: block;
  margin: 8px 0;
  color: #0066cc;
  font-weight: bold;
  text-decoration: none;
}

.popup button {
  margin-top: 10px;
  padding: 5px 10px;
}

.popup-content {
  position: relative;
}

.popup .close {
  position: absolute;
  top: 10px;
  right: 10px;
  font-size: 20px;
  cursor: pointer;
}

.popup h2 {
  font-size: 18px;
  margin-bottom: 15px;
}

