/* タイトルのデザイン */
.title1 {
  background-color: rgb(9, 9, 243);
  color: rgb(221, 225, 228);
  text-align: center;
  font-size: 2em;
  padding: 10px;
  margin-top: 25px;
  /* 上段との間隔を調整 */

}

.title2 {
  background-color: rgb(172, 225, 243);
  color: rgb(8, 8, 247);
  text-align: center;
  font-size: 2em;
  padding: 10px;
}

.title3 {
  font-size: 1.5em;
  font-weight: bold;
  color: #0033cc;
  margin-top: 32px;
  margin-bottom: 24px;
  text-align: center;
  background: #e6f2fa;
  padding: 10px 0 10px 0;
  border-radius: 8px;
