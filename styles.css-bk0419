}

/* ポップアップのスタイル */
/* ポップアップのスタイル */
.popup {
  display: none;
  /* 初期状態では非表示 */
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: rgb(251, 245, 245);
  border: 2px solid rgb(128, 0, 128);
  /* 枠線の色と太さ */
  border-radius: 15px;
  /* 枠線の角を丸くする */
  padding: 20px;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
  /* ポップアップに影をつける */
  text-align: center;
  z-index: 1000;
  /* ポップアップを最前面に */
}

/* 背景のオーバーレイ */
.overlay {
  display: none;
  /* 初期状態では非表示 */
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  /* 半透明の黒 */
  z-index: 999;
  /* ポップアップの背後に */
}


#message {
  display: none;
  margin-top: 20px;
}

#overlay {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

button {
  cursor: pointer;
  background-color: #007BFF;
  color: rgb(253, 248, 248);
  border: none;
  padding: 10px 20px;
  font-size: 14px;
  border-radius: 4px;
}

button:hover {
  background-color: #0056b3;
}

.kensu-border {
  color: rgb(26, 0, 128);
  margin: 20px auto;
  width: 60%;
  border: 2px solid rgb(128, 0, 128);
  padding: 10px;
  border-radius: 10px;
  text-align: center;
  /* テキストを中央寄せ */
  line-height: 0.7;
  /* 行の高さを調整 */
  display: block;
}

.kensu-border h3 {
  margin-bottom: 5px;
  /* h3要素の下の余白を調整 */
}

.kensu-border p {
  margin: 5px 0;
  /* p要素の上下の余白を調整 */
}

purple-line {
  border: 2px solid rgb(128, 0, 128);
  /* 紫色の枠線 */
  padding: 10px;
  /* 内側の余白 */
  margin: 10px;
  /* 外側の余白 */
  border-radius: 10px;
  /* 角の丸み */
  text-align: center;
  color: rgb(125, 3, 125);
  width: 60%;
  border: 2px solid rgb(131, 2, 131);
}

.audio-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  /* 水平方向中央寄せ */
}

.button-container {
  display: flex;
  justify-content: center;
  /* 水平方向中央寄せ */
  margin-top: 10px;
  /* ボタン間の余白 */
}

.button-container button {
  margin: 0 5px;
  /* ボタン間の余白 */
}

/* アクセス件数枠線 */
.purple-border {
  border: 2px solid rgb(128, 0, 128) !important;
  /* 枠線の色と太さを強制適用 */
  width: 400px;
  /* 横幅 */
  height: auto;
  /* 縦幅をコンテンツに合わせる */
  padding: 10px;
  /* 内側の余白 */
  box-sizing: border-box;
  /* 枠線を含めたサイズを計算 */
  display: flex;
  /* フレックスボックスで整列 */
  flex-direction: column;
  /* 子要素を縦方向に並べる */
  justify-content: center;
  /* 子要素を縦方向に中央配置 */
  align-items: center;
  /* 子要素を横方向に中央配置 */
  border-radius: 15px;
  /* 枠線の角を丸くする */
  margin: 0 auto;
  /* 枠全体を中央配置 */
}

.blue-bold {
  color: rgb(9, 9, 246);
  /* 青色の文字 */
  font-weight: bold;
  /* 太字にする */
  width: 400px;
  text-align: center;
}

p {
  margin: 5px 0;
  /* 各段落の間隔を設定 */
}

.purple-border-bgm {
  border: 2px solid rgb(126, 4, 126);
  /* 枠線の色と太さ */
  width: 400px;
  /* 横幅 */
  padding: 10px;
  /* 内側の余白 */
  box-sizing: border-box;
  /* 枠線を含めたサイズを計算 */
  border-radius: 15px;
  /* 枠線の角を丸くする */
  margin: 20px auto;
  /* 枠全体を中央配置 */
  text-align: center;
  /* テキストを中央揃えにする */
}

// 最終行の10列目だけ別クラスを使う 

/* ポップアップのスタイル */
#popup-message {
  max-width: 90%;
  /* 画面サイズに合わせて幅を調整 */
  display: none;
  /* 初期状態は非表示 */
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 300px;
  padding: 20px;
  background-color: rgb(255, 255, 255);
  /* Removed invalid comment syntax */
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
  z-index: 1000;
  text-align: center;
}

#overlay {
  display: none;
  /* 初期状態は非表示 */
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

button {
  cursor: pointer;
  background-color: #007BFF;
  color: rgb(255, 255, 255);
  border: none;
  padding: 10px 20px;
  font-size: 14px;
  border-radius: 4px;
}

button:hover {
  background-color: #0056b3;
}

/* 2〜9列目のセル：左右（縦罫線）を消す */
.no-vertical-border {
  border-left: none;
  border-right: none;
}

/* 10列目のセル：右線だけ表示 */
.right-border-only {
  border-left: none;
  border-top: none;
  border-bottom: none;
  border-right: 1px solid rgb(5, 5, 240);
}

.right-border-bottom {
  border-left: none;
  border-top: none;
  border-right: 1px solid rgb(9, 9, 245);
  border-bottom: 1px solid rgba(8, 8, 246, 0.968);
  /* 下線を表示 */
}

iframe {
  width: 90%;
  height: 400px;
  border: 2px solid rgb(128, 128, 128);
  margin-top: 20px;
}


table tr:nth-child(n+2):nth-child(-n+19) td:nth-child(n+2):nth-child(-n+10) {
  background-color: #ffcccb;
  /* 薄紅色 */
}

.highlight-box {
  background-color:rgb(21, 0, 255);
  color: white;
  text-align: center;
  padding: 6px 12px;
  font-size: 16px;
  font-weight: bold;
  margin-bottom: 15px;
  cursor: pointer;
  border: 2px solid hwb(253 0% 0%);
  border-radius: 5px;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
  transition: background-color 0.3s ease;
  position: fixed;
  left: 20px;
  top: 20px;
  z-index: 1000;
  width: auto;
}
.highlight-box:hover {
  background-color: #2200fff8;
  color: white;
}

.table-container {
  border: 2px solid rgb(6, 6, 248);
  padding: 20px;
  margin-top: 20px;
  overflow-x: auto;
}
table {
  border-collapse: collapse;
  width: 100%;
  table-layout: fixed;
  min-width: 600px;
}
th, td {
  border: 1px solid rgb(5, 5, 248);
  padding: 8px;
  word-break: break-word;
  cursor: pointer;
  position: relative;
}
tr:hover {
  background-color: #f0f8ff;
}
.tooltip {
  display: none;
  position: absolute;
  z-index: 999;
  background: rgba(0, 0, 0, 0.75);
  color: #fff;
  padding: 6px 10px;
  border-radius: 4px;
  font-size: 12px;
  max-width: 200px;
  pointer-events: none;
}
.parent {
  font-weight: bold;
  color: green;
}
.child {
  padding-left: 1em;
  color: #333;
}
@media (max-width: 768px) {
  td {
    font-size: 14px;
    padding: 6px;
  }
}